{
  "name": "uiu-alumni-connect",
  "version": "0.1.0",
  "private": true,
  "description": "A modern alumni-student networking platform for university communities.",
  "scripts": {
    "dev": "npm run dev --workspace @uiu-alumni/web",
    "dev:web": "npm run dev --workspace @uiu-alumni/web",
    "dev:api": "npm run dev --workspace @uiu-alumni/api",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace @uiu-alumni/api",
    "build:web": "npm run build --workspace @uiu-alumni/web",
    "lint": "npm run lint --workspaces",
    "start:api": "npm run start --workspace @uiu-alumni/api",
    "start:web": "npm run start --workspace @uiu-alumni/web",
    "typecheck": "npm run typecheck --workspaces",
    "test": "jest --runInBand",
    "prisma:generate": "dotenv -e .env.local -e .env -- prisma generate",
    "prisma:migrate": "dotenv -e .env.local -e .env -- prisma migrate dev",
    "prisma:push": "dotenv -e .env.local -e .env -- prisma db push"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.3"
  }
}
